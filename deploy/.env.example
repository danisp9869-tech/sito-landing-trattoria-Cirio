# Copia questo file in deploy/.env e compila i valori per il deploy MANUALE
# (bash deploy/deploy.sh). Il file deploy/.env è ignorato da git: non finisce
# nel repository. Gli stessi valori vanno impostati come "Secrets" su GitHub
# per il deploy automatico (vedi deploy/README.md).

# Server
VPS_HOST=1.2.3.4                 # IP o hostname del VPS
VPS_USER=deploy                  # utente SSH (con sudo NOPASSWD, vedi README)
VPS_PORT=22                      # porta SSH (default 22)
VPS_TARGET_DIR=/var/www/cirio    # cartella servita da Nginx

# Dominio e SSL
VPS_DOMAIN=anticatrattoriacirio.it   # dominio del sito (senza http://)
VPS_EMAIL=info@anticatrattoriacirio.it  # email per Let's Encrypt
VPS_INCLUDE_WWW=true             # includi anche www.DOMINIO (true/false)

# Chiave SSH privata da usare per connettersi (percorso locale)
VPS_SSH_KEY_FILE=~/.ssh/id_rsa
